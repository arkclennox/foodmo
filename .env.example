# Database
# Local dev default uses SQLite. For production (Vercel) swap to your Postgres
# provider (Supabase, Neon, Vercel Postgres) and update prisma/schema.prisma
# provider to "postgresql".
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@host:5432/direktori_kuliner"

# Public site URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Session & JWT secrets — generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"
JWT_SECRET="change-me-to-a-long-random-string"

# API key hashing secret — generate with: openssl rand -hex 32
API_KEY_HASH_SECRET="change-me-to-a-long-random-string"

# Initial admin account (used by prisma seed). Change in production!
ADMIN_EMAIL="admin@direktori-kuliner.id"
ADMIN_PASSWORD="admin1234"
ADMIN_NAME="Admin"
